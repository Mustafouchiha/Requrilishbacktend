# ── MongoDB Atlas ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/?appName=Cluster0

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_strong_jwt_secret_here

# ── Server port ──────────────────────────────────────────────────
PORT=5000

# ── PostgreSQL (Neon.tech bepul: https://neon.tech) ───────────────
# Neon.tech da bepul project yaratib, connection string ni oling:
POSTGRES_URL=postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require

# ── To'lov operatori ─────────────────────────────────────────────
OPERATOR_CARD=8600 0000 0000 0000
OPERATOR_NAME=ReMarket Operator

# ── SMS (eskiz.uz) ────────────────────────────────────────────────
ESKIZ_EMAIL=your_email@gmail.com
ESKIZ_PASSWORD=your_eskiz_password
SMS_FROM=2580
